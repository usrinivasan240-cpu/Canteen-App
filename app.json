{
  "expo": {
    "name": "Canteen App",
    "slug": "canteen-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#7c3aed"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.canteen.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7c3aed"
      },
      "package": "com.canteen.app"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Canteen App to access camera for QR scanning"
        }
      ]
    ]
  }
}
